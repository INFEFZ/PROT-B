{
  "tasks": [
    {
      "type": "cppbuild",
      "label": "C/C++: gcc Aktive Datei kompilieren",
      // "command": "/usr/bin/gcc",
      "command": "/usr/bin/gcc",
      "args": [
        "-fdiagnostics-color=always",
        "-g",
        "${file}",
        "-o",
        "${fileDirname}/build/${fileBasenameNoExtension}"
        // "${workspaceFolder}/build/${fileBasenameNoExtension}"
      ],
      "options": {
        // "cwd": "${workspaceFolder}"
        "cwd": "${fileDirname}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "detail": "Vom Debugger generierte Aufgabe."
    }
  ],
  "version": "2.0.0"
}
