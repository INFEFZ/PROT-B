{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build labyrinth",
      "type": "shell",
      "command": "/usr/bin/gcc",
      "args": [
        "-std=c11",
        "-O2",
        "-g",
        "${workspaceFolder}/main.c",
        "-o",
        "${workspaceFolder}/labyrinth"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": ["$gcc"],
      "group": { "kind": "build", "isDefault": true }
    }
  ]
}
